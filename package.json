{
  "name": "@anmol-srv/cortex",
  "version": "0.3.0",
  "type": "module",
  "description": "Persistent memory layer for Claude Code sessions — ingests documents, extracts facts, answers questions via MCP",
  "bin": {
    "cortex": "src/cli.js"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "!src/scripts/",
    "prompts/",
    "public/",
    "knexfile.js"
  ],
  "keywords": [
    "rag",
    "knowledge-base",
    "mcp",
    "llm",
    "memory",
    "claude",
    "claude-code",
    "context-layer",
    "pgvector"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "knex": "^3.1.0",
    "lodash-es": "^4.17.23",
    "nanoid": "^5.1.7",
    "pg": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "vitest": "^4.0.18"
  }
}
